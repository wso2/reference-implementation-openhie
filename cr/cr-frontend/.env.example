# Required: authentication mode.
# Options: "oidc" | "simulated"
# The app will not start if this is missing or set to an invalid value.
VITE_AUTH_MODE=oidc

# Required when VITE_AUTH_MODE=oidc
#
# VITE_OIDC_AUTHORITY: The OIDC issuer URL. The library fetches the provider's
# discovery document from {authority}/.well-known/openid-configuration.
#
# IMPORTANT for Asgardeo: use the OAuth2 token endpoint path, NOT the org base URL.
# The org base URL redirects the discovery request, which browsers block (CORS).
#
# Examples:
#   Asgardeo:  https://api.asgardeo.io/t/your-org-name/oauth2/token   ← note /oauth2/token
#   Keycloak:  https://your-keycloak-host/realms/your-realm
#   Auth0:     https://your-tenant.auth0.com
#   Okta:      https://your-org.okta.com/oauth2/default
#   Azure AD:  https://login.microsoftonline.com/your-tenant-id/v2.0
#
# Set Authorized Redirect URL in your IdP to your app's origin (e.g. http://localhost:5173)
VITE_OIDC_CLIENT_ID=your-client-id-here
VITE_OIDC_AUTHORITY=https://your-oidc-provider-issuer-url

# Optional: extra scopes beyond "openid profile email"
# Asgardeo requires "groups" to include group membership in the ID token.
# Keycloak, Azure AD, Okta: leave blank — groups are configured server-side.
# VITE_OIDC_EXTRA_SCOPES=groups

# Optional: override redirect URIs (defaults to your app's origin)
# Set these if your IdP requires an exact callback path (e.g. /auth/callback)
# VITE_OIDC_REDIRECT_URI=http://localhost:5173
# VITE_OIDC_POST_LOGOUT_REDIRECT_URI=http://localhost:5173

# Optional: override the OIDC discovery document URL.
# Use when the discovery URL doesn't follow {authority}/.well-known/openid-configuration.
# VITE_OIDC_METADATA_URL=https://your-provider/.well-known/openid-configuration

# Optional: ID token claim that contains group membership (default: "groups")
# Auth0 custom claim example: https://myapp.com/groups
# Azure AD note: the "groups" claim contains object GUIDs, not group name strings
# VITE_OIDC_GROUPS_CLAIM=groups
