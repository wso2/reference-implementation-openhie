# Asgardeo Identity Provider Configuration
# Create a Single Page Application in https://console.asgardeo.io
# Set Authorized Redirect URL to your app's origin (e.g., http://localhost:5173)
#
# For role-based access, create groups "admin" and "viewer" in Asgardeo,
# assign users to groups, and enable "groups" in the app's User Attributes.
#
# Leave these blank to use simulated authentication (dev mode)
VITE_ASGARDEO_CLIENT_ID=your-client-id-here
VITE_ASGARDEO_BASE_URL=https://api.asgardeo.io/t/your-org-name
